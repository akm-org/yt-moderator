APP_NAME=YouTube AI Moderator
APP_ENV=development
BASE_URL=http://localhost:8000
SECRET_KEY=replace-with-a-strong-random-secret-at-least-32-chars
SECURE_COOKIES=false
ALLOWED_HOSTS=*

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
CHANNEL_ID=
YOUTUBE_SETUP_TOKEN=replace-with-random-token-for-friend-oauth-link

DISCORD_WEBHOOK=

WORKER_ENABLED=true
AUTO_MODERATE=true
SEND_WARNING_MESSAGES=false
DEFAULT_TIMEOUT_SECONDS=300

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
RATE_LIMIT_PER_MINUTE=240
LOGIN_RATE_LIMIT_PER_MINUTE=8
